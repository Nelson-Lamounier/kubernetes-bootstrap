# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# Ruff
.ruff_cache/

# Pytest
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Node (for TS scripts)
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs (keep checked-in logs, ignore runtime)
*.log
!logs/

# CDK / Infra
infra/node_modules/
infra/cdk.out/
infra/dist/
infra/install-state.gz
infra/.yarn/cache/
infra/.yarn/unplugged/
infra/.yarn/build-state.yml

# TypeScript build output
*.js.map
*.d.ts
# Prevent tsc run-without-tsconfig from polluting source tree
infra/lib/**/*.js
infra/bin/**/*.js
.claude/settings.local.json

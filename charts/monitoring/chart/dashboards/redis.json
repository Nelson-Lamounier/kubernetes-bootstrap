    {
      "id": 203,
      "type": "stat",
      "title": "Connected clients",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 6,

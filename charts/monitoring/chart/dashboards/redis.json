{
  "uid": "redis-overview",
  "title": "Redis \u2014 Cache Effectiveness & Server Health",
  "tags": [
    "redis",
    "cache",
    "bedrock",
    "tucaken"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "links": [],
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Cache effectiveness \u2014 is Bedrock/read cache actually caching",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Caches disabled",
      "description": "Caches in fail-open disabled state (REDIS_CACHE_HOST unset).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(redis_cache_enabled == 0) or vector(0)",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Overall hit ratio",
      "description": "Hits / (hits+misses) across all caches, 1h.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(redis_cache_requests_total{result=\"hit\"}[1h])) / clamp_min(sum(rate(redis_cache_requests_total{result=~\"hit|miss\"}[1h])),1)",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Bedrock calls avoided (24h)",
      "description": "Exact-cache hits on AI-gen scopes = Bedrock invocations skipped.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(redis_cache_requests_total{cache=~\"aigen:.*\",result=\"hit\"}[24h]))",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 104,
      "type": "stat",
      "title": "Cache errors (1h)",
      "description": "Cache op errors (fail-open to miss).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(redis_cache_requests_total{result=\"error\"}[1h]))",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 110,
      "type": "timeseries",
      "title": "Hit ratio by cache",
      "description": "Per-scope hit ratio \u2014 a sustained ~0 with traffic = caching broken for that scope.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cache) (rate(redis_cache_requests_total{result=\"hit\"}[5m])) / clamp_min(sum by (cache) (rate(redis_cache_requests_total{result=~\"hit|miss\"}[5m])),1)",
          "legendFormat": "{{cache}}"
        }
      ]
    },
    {
      "id": 111,
      "type": "timeseries",
      "title": "Cache requests by cache / result",
      "description": "Hit/miss/error rate per cache.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cache,result) (rate(redis_cache_requests_total[5m]))",
          "legendFormat": "{{cache}} {{result}}"
        }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "Redis server health (per instance: redis-cache, redis-broker)",
      "collapsed": false,
      "gridPos": {

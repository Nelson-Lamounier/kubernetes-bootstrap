      "targets": [
        {
          "refId": "A",
          "expr": "min by (namespace) (redis_up)",
          "legendFormat": "{{namespace}}"
        }
      ]
    },
    {
      "id": 202,
      "type": "stat",
      "title": "Memory used",
      "description": "Used memory per instance.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 14,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",

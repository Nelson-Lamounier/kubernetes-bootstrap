    {
      "id": 213,
      "type": "timeseries",
      "title": "Server keyspace hit ratio (global)",
      "description": "Redis-server-wide hit ratio (all keys) \u2014 distinct from per-scope app hit ratio above.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace) (rate(redis_keyspace_hits_total[5m])) / clamp_min(sum by (namespace) (rate(redis_keyspace_hits_total[5m]))+sum by (namespace) (rate(redis_keyspace_misses_total[5m])),1)",
          "legendFormat": "{{namespace}}"
        }
      ]
    },

    {
      "id": 210,
      "type": "timeseries",
      "title": "Memory used vs maxmemory %",
      "description": "Only meaningful where maxmemory is set (cache=350mb; broker has no cap).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "redis_memory_used_bytes / clamp_min(redis_memory_max_bytes,1)",
          "legendFormat": "{{namespace}}"
        }
      ]
    },
    {
      "id": 211,
      "type": "timeseries",
      "title": "Evicted / expired keys",
      "description": "Sustained evictions on the cache = maxmemory pressure.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace) (rate(redis_evicted_keys_total[5m]))",
          "legendFormat": "{{namespace}} evicted"
        },
        {
          "refId": "B",
          "expr": "sum by (namespace) (rate(redis_expired_keys_total[5m]))",
          "legendFormat": "{{namespace}} expired"
        }
      ]
    },

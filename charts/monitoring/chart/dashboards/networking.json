{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "tags": ["networking", "traefik", "nlb", "cni"],
  "title": "Networking — Traefik / NLB / CNI",
  "uid": "networking",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      { "name": "entrypoint", "type": "query", "datasource": { "type": "prometheus", "uid": "prometheus" }, "query": "label_values(traefik_entrypoint_requests_total, entrypoint)", "refresh": 2, "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" } },
      { "name": "service", "type": "query", "datasource": { "type": "prometheus", "uid": "prometheus" }, "query": "label_values(traefik_service_requests_total, service)", "refresh": 2, "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" } }
    ]
  },
  "panels": [
    { "type": "row", "id": 100, "title": "Traefik — request flow", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 101, "type": "timeseries", "title": "Requests/sec by entrypoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "sum by (entrypoint) (rate(traefik_entrypoint_requests_total{entrypoint=~\"$entrypoint\"}[5m]))", "legendFormat": "{{entrypoint}}" }
      ]
    },
    {
      "id": 102, "type": "timeseries", "title": "p95 entrypoint latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, entrypoint) (rate(traefik_entrypoint_request_duration_seconds_bucket{entrypoint=~\"$entrypoint\"}[5m])))", "legendFormat": "{{entrypoint}}" }
      ]
    },
    {
      "id": 103, "type": "timeseries", "title": "Per-service request rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "sum by (service) (rate(traefik_service_requests_total{service=~\"$service\"}[5m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 104, "type": "timeseries", "title": "Per-service 5xx ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 } },
      "targets": [
        { "refId": "A", "expr": "sum by (service) (rate(traefik_service_requests_total{service=~\"$service\",code=~\"5..\"}[5m])) / clamp_min(sum by (service) (rate(traefik_service_requests_total{service=~\"$service\"}[5m])), 0.001)", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 105, "type": "stat", "title": "Open connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "sum(traefik_open_connections)" }]
    },
    {
      "id": 106, "type": "stat", "title": "Service retries / sec (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "ops", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 5 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "refId": "A", "expr": "sum(rate(traefik_service_retries_total[5m]))" }]
    },
    {
      "id": 107, "type": "stat", "title": "TLS handshake errors / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "sum(rate(traefik_tls_certs_not_after[5m] offset 1d))" }]
    },
    {
      "id": 108, "type": "stat", "title": "Cert age min (days)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "d", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 14 }, { "color": "green", "value": 30 }] } } },
      "options": { "reduceOptions": { "calcs": ["min"] }, "colorMode": "background" },
      "targets": [{ "refId": "A", "expr": "(min(traefik_tls_certs_not_after) - time()) / 86400" }]
    },
    { "type": "row", "id": 200, "title": "AWS NLB — target health", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 } },
    {
      "id": 201, "type": "timeseries", "title": "Healthy / Unhealthy hosts",
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } },
      "targets": [
        { "refId": "A", "namespace": "AWS/NetworkELB", "metricName": "HealthyHostCount", "statistic": "Average", "dimensions": {} },
        { "refId": "B", "namespace": "AWS/NetworkELB", "metricName": "UnHealthyHostCount", "statistic": "Average", "dimensions": {} }
      ]
    },
    {
      "id": 202, "type": "timeseries", "title": "Active flows + processed bytes",
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "fieldConfig": { "defaults": { "min": 0 } },
      "targets": [
        { "refId": "A", "namespace": "AWS/NetworkELB", "metricName": "ActiveFlowCount", "statistic": "Sum" },
        { "refId": "B", "namespace": "AWS/NetworkELB", "metricName": "ProcessedBytes", "statistic": "Sum" }
      ]
    },
    {
      "id": 203, "type": "timeseries", "title": "TCP target reset count",
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 30 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] } } },
      "targets": [
        { "refId": "A", "namespace": "AWS/NetworkELB", "metricName": "TCP_Target_Reset_Count", "statistic": "Sum" }
      ]
    },
    {
      "id": 204, "type": "logs", "title": "NLB target deregistration events (Loki)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 30 },
      "options": { "showTime": true, "wrapLogMessage": true },
      "targets": [
        { "refId": "A", "expr": "{job=\"cloudtrail\"} |~ \"DeregisterTargets|RegisterTargets\"" }
      ]
    },
    { "type": "row", "id": 300, "title": "Cluster networking — Calico CNI + DNS", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 } },
    {
      "id": 301, "type": "stat", "title": "Calico BGP peers established",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 37 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "refId": "A", "expr": "sum(felix_active_local_endpoints)" }]
    },
    {
      "id": 302, "type": "stat", "title": "IP pool free %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 37 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.20 }, { "color": "green", "value": 0.50 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "refId": "A", "expr": "sum(felix_ipam_blocks_free) / clamp_min(sum(felix_ipam_blocks_total), 1)" }]
    },
    {
      "id": 303, "type": "timeseries", "title": "CoreDNS query rate by rcode",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "sum by (rcode) (rate(coredns_dns_responses_total[5m]))", "legendFormat": "{{rcode}}" }
      ]
    },
    {
      "id": 304, "type": "timeseries", "title": "CoreDNS p95 latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(coredns_dns_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 305, "type": "timeseries", "title": "kube-proxy sync errors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 45 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } },
      "targets": [
        { "refId": "A", "expr": "sum by (instance) (increase(kubeproxy_sync_proxy_rules_iptables_restore_failures_total[5m]))", "legendFormat": "{{instance}}" }
      ]
    }
  ]
}

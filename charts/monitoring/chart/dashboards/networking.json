        { "refId": "A", "namespace": "AWS/ApplicationELB", "metricName": "HealthyHostCount", "statistic": "Average", "dimensions": { "LoadBalancer": "app/k8s-public-f8655bfb7e/78080c3d6ec33605", "TargetGroup": "targetgroup/k8s-monitori-faroprox-25fb7e8eec/1717058bc4ff459b" }, "matchExact": true, "label": "healthy" },
        { "refId": "B", "namespace": "AWS/ApplicationELB", "metricName": "UnHealthyHostCount", "statistic": "Average", "dimensions": { "LoadBalancer": "app/k8s-public-f8655bfb7e/78080c3d6ec33605", "TargetGroup": "targetgroup/k8s-monitori-faroprox-25fb7e8eec/1717058bc4ff459b" }, "matchExact": true, "label": "unhealthy" },
        { "refId": "C", "namespace": "AWS/ApplicationELB", "metricName": "TargetResponseTime", "statistic": "p95", "dimensions": { "LoadBalancer": "app/k8s-public-f8655bfb7e/78080c3d6ec33605", "TargetGroup": "targetgroup/k8s-monitori-faroprox-25fb7e8eec/1717058bc4ff459b" }, "matchExact": true, "label": "p95 latency" }

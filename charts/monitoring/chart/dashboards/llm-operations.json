      },
      {
        "name": "pipeline",
        "type": "custom",
        "label": "Pipeline",
        "query": "all,ingestion,resume-import,article-pipeline,job-strategist,profile-extraction,repo-sync",
        "current": { "text": "all", "value": "all" },
        "options": [
          { "text": "all", "value": "all", "selected": true },
          { "text": "ingestion", "value": "ingestion", "selected": false },
          { "text": "resume-import", "value": "resume-import", "selected": false },
          { "text": "article-pipeline", "value": "article-pipeline", "selected": false },
          { "text": "job-strategist", "value": "job-strategist", "selected": false },
          { "text": "profile-extraction", "value": "profile-extraction", "selected": false },

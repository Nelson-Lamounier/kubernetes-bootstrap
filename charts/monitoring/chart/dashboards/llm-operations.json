          "legendFormat": "p25"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.75, sum by (le) (rate(ingestion_kb_quality_score_bucket[1h])))",
          "legendFormat": "p75"
        }
      ]
    },

    {
      "id": 504,
      "type": "table",
      "title": "Latest RAG eval scores",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 69 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "relevance_pos" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "recall_at_k" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "relevance_neg_leak" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "max_cosine" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          }
        ]
      },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT to_char(run_at, 'YYYY-MM-DD HH24:MI') AS run_at,\n  tool,\n  query_count,\n  ROUND(mean_relevance_positive::numeric, 3) AS relevance_pos,\n  ROUND(mean_recall_at_k::numeric, 3) AS recall_at_k,\n  ROUND(mean_relevance_negative::numeric, 3) AS relevance_neg_leak,\n  ROUND(mean_max_cosine::numeric, 3) AS max_cosine\nFROM rag_eval_runs\nORDER BY run_at DESC\nLIMIT 5"
        }
      ]
    },
    {
      "id": 505,
      "type": "timeseries",
      "title": "RAG eval score trend",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [

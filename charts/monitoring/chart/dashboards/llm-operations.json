        ],
        "description": "Scope RDS prompt_invocations panels. all keeps the cross-pipeline view."
      },
      {
        "name": "user_id",
        "type": "textbox",
        "label": "User ID",
        "query": "",
        "current": { "text": "", "value": "" },
        "description": "Optional UUID filter for RDS attribution tables."
      },
      {
        "name": "repo_name",
        "type": "textbox",
        "label": "Repo",
        "query": "",
        "current": { "text": "", "value": "" },
        "description": "Optional repo_name filter for ingestion attribution tables."
      },
      {
        "name": "trace_id",
        "type": "textbox",
        "label": "Trace ID",
        "query": "",
        "current": { "text": "", "value": "" },
        "description": "Paste a trace ID to open the exact Tempo trace."
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "LLM Operations - Cost, Latency & Quality",
  "uid": "llm-operations",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## LLM Operations\n\nCentral view for Bedrock-backed workflows: spend, token volume, latency, errors, cache savings, retrieval quality, and trace pivots. Use this dashboard for triage and governance; drill into the ingestion, resume import, background jobs, Bedrock spend, and AI Applications RED dashboards for workflow-level detail."
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Executive summary",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Recorded LLM spend (24h)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT ROUND(COALESCE(SUM(total_cost_cents), 0) / 100.0, 4) AS usd\nFROM prompt_invocations\nWHERE invoked_at > NOW() - INTERVAL '24 hours'\n  AND (${pipeline:sqlstring} = 'all' OR pipeline = ${pipeline:sqlstring})\n  AND (${user_id:sqlstring} = '' OR user_id::text = ${user_id:sqlstring})\n  AND (${repo_name:sqlstring} = '' OR repo_name = ${repo_name:sqlstring})"
        }
      ]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "LLM invocations (24h)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT COUNT(*) AS invocations\nFROM prompt_invocations\nWHERE invoked_at > NOW() - INTERVAL '24 hours'\n  AND (${pipeline:sqlstring} = 'all' OR pipeline = ${pipeline:sqlstring})\n  AND (${user_id:sqlstring} = '' OR user_id::text = ${user_id:sqlstring})\n  AND (${repo_name:sqlstring} = '' OR repo_name = ${repo_name:sqlstring})"
        }
      ]
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Input tokens (24h)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT COALESCE(SUM(user_message_tokens + system_prompt_tokens), 0) AS tokens\nFROM prompt_invocations\nWHERE invoked_at > NOW() - INTERVAL '24 hours'\n  AND (${pipeline:sqlstring} = 'all' OR pipeline = ${pipeline:sqlstring})\n  AND (${user_id:sqlstring} = '' OR user_id::text = ${user_id:sqlstring})\n  AND (${repo_name:sqlstring} = '' OR repo_name = ${repo_name:sqlstring})"
        }
      ]
    },
    {
      "id": 104,
      "type": "stat",
      "title": "Output tokens (24h)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT COALESCE(SUM(output_tokens), 0) AS tokens\nFROM prompt_invocations\nWHERE invoked_at > NOW() - INTERVAL '24 hours'\n  AND (${pipeline:sqlstring} = 'all' OR pipeline = ${pipeline:sqlstring})\n  AND (${user_id:sqlstring} = '' OR user_id::text = ${user_id:sqlstring})\n  AND (${repo_name:sqlstring} = '' OR repo_name = ${repo_name:sqlstring})"
        }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "Spend attribution and billing coverage",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 }
    },
    {
      "id": 201,
      "type": "timeseries",
      "title": "Recorded spend by pipeline",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT $__timeGroupAlias(invoked_at, '1h'),\n  pipeline AS metric,\n  ROUND(SUM(total_cost_cents) / 100.0, 4) AS usd\nFROM prompt_invocations\nWHERE $__timeFilter(invoked_at)\n  AND (${pipeline:sqlstring} = 'all' OR pipeline = ${pipeline:sqlstring})\n  AND (${user_id:sqlstring} = '' OR user_id::text = ${user_id:sqlstring})\n  AND (${repo_name:sqlstring} = '' OR repo_name = ${repo_name:sqlstring})\nGROUP BY 1, pipeline\nORDER BY 1"
        }
      ]
    },
    {
      "id": 202,
      "type": "table",
      "title": "Recorded spend by pipeline + agent (24h)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "usd" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_latency_ms" },
            "properties": [{ "id": "unit", "value": "ms" }]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "usd", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT pipeline,\n  agent,\n  COUNT(*) AS invocations,\n  COALESCE(SUM(user_message_tokens + system_prompt_tokens), 0) AS in_tokens,\n  COALESCE(SUM(output_tokens), 0) AS out_tokens,\n  ROUND(SUM(total_cost_cents) / 100.0, 4) AS usd,\n  ROUND(AVG(latency_ms)::numeric, 0) AS avg_latency_ms\nFROM prompt_invocations\nWHERE invoked_at > NOW() - INTERVAL '24 hours'\n  AND (${pipeline:sqlstring} = 'all' OR pipeline = ${pipeline:sqlstring})\n  AND (${user_id:sqlstring} = '' OR user_id::text = ${user_id:sqlstring})\n  AND (${repo_name:sqlstring} = '' OR repo_name = ${repo_name:sqlstring})\nGROUP BY pipeline, agent\nORDER BY usd DESC NULLS LAST\nLIMIT 50"
        }
      ]
    },
    {
      "id": 203,
      "type": "table",
      "title": "AWS-billed Bedrock service lines (30d)",
      "description": "Ground truth from Cost Explorer via Steampipe. Compare with recorded RDS spend to find uninstrumented Bedrock callers.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "steampipe" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "usd_30d" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "usd_30d", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "steampipe" },
          "rawSql": "WITH costs AS (\n  SELECT COALESCE(service, '(unknown service)') AS service,\n    round(sum(unblended_cost_amount::numeric), 2) AS usd_30d\n  FROM aws_cost_by_service_daily\n  WHERE period_start >= (current_date - interval '30 days')\n    AND (\n      service ILIKE '%bedrock%'\n      OR service ILIKE '%claude%'\n      OR service ILIKE '%anthropic%'\n      OR service ILIKE '%titan%'\n      OR service ILIKE '%nova%'\n      OR service ILIKE '%mistral%'\n      OR service ILIKE '%llama%'\n      OR service ILIKE '%cohere%'\n      OR service ILIKE '%ai21%'\n    )\n  GROUP BY service\n)\nSELECT service, usd_30d\nFROM costs\nUNION ALL\nSELECT '(no AWS-billed Bedrock cost returned for 30d)' AS service, 0::numeric AS usd_30d\nWHERE NOT EXISTS (SELECT 1 FROM costs)\nORDER BY usd_30d DESC"
        }
      ]
    },
    {
      "id": 204,
      "type": "table",
      "title": "Recorded spend by user and repo (24h)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "usd" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "usd", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT COALESCE(u.email, pi.user_id::text) AS user_email,\n  COALESCE(pi.repo_name, '(no repo)') AS repo,\n  pi.pipeline,\n  COUNT(*) AS invocations,\n  COALESCE(SUM(pi.user_message_tokens + pi.system_prompt_tokens), 0) AS in_tokens,\n  COALESCE(SUM(pi.output_tokens), 0) AS out_tokens,\n  ROUND(SUM(pi.total_cost_cents) / 100.0, 4) AS usd\nFROM prompt_invocations pi\nLEFT JOIN users u ON u.id = pi.user_id\nWHERE pi.invoked_at > NOW() - INTERVAL '24 hours'\n  AND (${pipeline:sqlstring} = 'all' OR pi.pipeline = ${pipeline:sqlstring})\n  AND (${user_id:sqlstring} = '' OR pi.user_id::text = ${user_id:sqlstring})\n  AND (${repo_name:sqlstring} = '' OR pi.repo_name = ${repo_name:sqlstring})\nGROUP BY user_email, repo, pi.pipeline\nORDER BY usd DESC NULLS LAST\nLIMIT 50"
        }
      ]
    },
    {
      "id": 300,
      "type": "row",
      "title": "Live Bedrock runtime",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 301,
      "type": "stat",
      "title": "Bedrock cost rate",
      "description": "Prometheus rate from application instrumentation. Use with RDS cost tables to catch missing attribution.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(bedrock_cost_usd_total[5m])) * 3600" }
      ]
    },
    {
      "id": 302,
      "type": "stat",
      "title": "Bedrock calls (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(bedrock_calls_total[5m]))" }
      ]
    },
    {
      "id": 303,
      "type": "stat",
      "title": "Output tokens (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(bedrock_tokens_total{kind=\"output\"}[5m]))" }
      ]
    },
    {
      "id": 304,
      "type": "stat",
      "title": "Cache hit ratio (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(redis_cache_requests_total{cache=~\"aigen:.*\",result=\"hit\"}[5m])) or vector(0)) / clamp_min((sum(rate(redis_cache_requests_total{cache=~\"aigen:.*\",result=~\"hit|miss\"}[5m])) or vector(0)), 1)"
        }
      ]
    },
    {
      "id": 305,
      "type": "timeseries",
      "title": "Tokens per minute by model + kind",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model, kind) (rate(bedrock_tokens_total[5m])) * 60",
          "legendFormat": "{{model}} / {{kind}}"
        }
      ]
    },
    {
      "id": 306,
      "type": "timeseries",
      "title": "CloudWatch Bedrock invocations by model",
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/Bedrock",
          "metricName": "Invocations",
          "dimensions": { "ModelId": "*" },
          "statistic": "Sum",
          "period": "300",
          "region": "eu-west-1"
        }
      ]
    },
    {
      "id": 400,
      "type": "row",
      "title": "Latency and reliability",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }
    },
    {
      "id": 401,
      "type": "timeseries",
      "title": "Resume import Bedrock duration p95 by purpose",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, purpose) (rate(resume_import_bedrock_duration_seconds_bucket[5m])))",
          "legendFormat": "{{purpose}}"
        }
      ]
    },
    {
      "id": 402,
      "type": "timeseries",
      "title": "Application-recorded LLM latency by pipeline + agent",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT $__timeGroupAlias(invoked_at, '1h'),\n  pipeline || ' / ' || agent AS metric,\n  ROUND(AVG(latency_ms)::numeric, 0) AS avg_latency_ms\nFROM prompt_invocations\nWHERE $__timeFilter(invoked_at)\n  AND (${pipeline:sqlstring} = 'all' OR pipeline = ${pipeline:sqlstring})\n  AND (${user_id:sqlstring} = '' OR user_id::text = ${user_id:sqlstring})\n  AND (${repo_name:sqlstring} = '' OR repo_name = ${repo_name:sqlstring})\nGROUP BY 1, metric\nORDER BY 1"
        }
      ]
    },
    {
      "id": 403,
      "type": "stat",
      "title": "Bedrock exceptions from CloudWatch logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 50 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"cloudwatch\"} |~ \"ValidationException|ThrottlingException|ServiceQuotaExceededException|ResourceNotFoundException|ModelTimeoutException|Bedrock\" [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 404,
      "type": "stat",
      "title": "LLM workflow warnings and errors",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 50 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({namespace=~\"admin-api|ingestion|resume-import|article-pipeline|job-strategist\"} |~ `(?i)\\b(warn|warning|error|exception|fatal|throttl|bedrock)\\b` [$__range])) or vector(0)"
        }
      ]

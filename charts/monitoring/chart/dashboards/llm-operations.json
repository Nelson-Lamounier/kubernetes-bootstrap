          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "rds-postgres" },
          "rawSql": "SELECT run_at AS time,\n  mean_relevance_positive AS \"relevance_pos\",\n  mean_recall_at_k AS \"recall_at_k\",\n  mean_relevance_negative AS \"relevance_neg_leak\",\n  mean_max_cosine AS \"max_cosine\"\nFROM rag_eval_runs\nORDER BY run_at"
        }
      ]
    },

    {
      "id": 50,
      "type": "row",
      "title": "Duration distribution (Pushgateway histograms)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 55
      }
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Ingestion duration p50/p95",
      "description": "Per-run wall-clock from Pushgateway histogram. Watch for the gap between p50 and p95 widening — that's when a slow repo (lots of files / large diff) drags fleet latency.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 56
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ingestion_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ingestion_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 52,
      "type": "timeseries",
      "title": "Resume-import duration p50/p95",
      "description": "Same as ingestion but for resume_import_duration_seconds. The resume-import dashboard breaks this down per sub-step.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 56
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(resume_import_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(resume_import_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 53,
      "type": "timeseries",
      "title": "K8s job status timeline — both pipelines",
      "description": "Active / succeeded / failed counts from kube-state-metrics. Useful for seeing burst patterns and TTL behaviour. Scoped to $pipeline.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 64
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_job_status_active{namespace=~\"${pipeline:regex}|(ingestion|resume-import)\"})",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "sum(kube_job_status_succeeded{namespace=~\"${pipeline:regex}|(ingestion|resume-import)\"})",
          "legendFormat": "succeeded"
        },
        {
          "refId": "C",
          "expr": "sum(kube_job_status_failed{namespace=~\"${pipeline:regex}|(ingestion|resume-import)\"})",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "id": 54,
      "type": "timeseries",
      "title": "Throughput — chunks + embeddings created (1 h rate)",
      "description": "Sum of ingestion_chunks_total + resume_import_embeddings_created_total. Both pipelines create vector store rows; this is the unified throughput signal.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 64
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ingestion_chunks_total[1h]))",
          "legendFormat": "ingestion chunks"
        },
        {
          "refId": "B",
          "expr": "sum(increase(resume_import_embeddings_created_total[1h]))",
          "legendFormat": "resume embeddings"
        }
      ]
    },
    {
      "id": 60,
      "type": "row",
      "title": "Spend — Bedrock cost across both pipelines (RDS)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 72
      }
    },
    {
      "id": 61,
      "type": "table",
      "title": "Bedrock spend by pipeline + agent (24 h)",
      "description": "Aggregates prompt_invocations across both pipelines so you can compare $ per workload. resume-import / ingestion appear as separate rows.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "rds-postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 73
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  pipeline,\n  agent,\n  COUNT(*)                                            AS invocations,\n  COALESCE(SUM(user_message_tokens + system_prompt_tokens), 0) AS in_tokens,\n  COALESCE(SUM(output_tokens), 0)                              AS out_tokens,\n  ROUND(SUM(total_cost_cents) / 100, 4)               AS usd,\n  ROUND(AVG(latency_ms)::numeric, 0)                  AS avg_latency_ms\nFROM prompt_invocations\nWHERE invoked_at > NOW() - INTERVAL '24 hours'\nGROUP BY pipeline, agent\nORDER BY usd DESC NULLS LAST\nLIMIT 50"
        }
      ]
    }
  ],

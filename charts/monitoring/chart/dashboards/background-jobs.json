{
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=\"github-actions\", event=~\"deploy_succeeded|deploy_failed\", service=~\"ingestion|resume-import-processor\"} | json",
        "iconColor": "blue",
        "titleFormat": "{{event}} {{service}} {{git_sha}}",
        "textFormat": "{{run_url}}"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "tags": [

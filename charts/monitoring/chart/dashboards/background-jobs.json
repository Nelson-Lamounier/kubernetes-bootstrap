      "id": 11,
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ resource.service.name =~ \"ingestion|ingestion-worker|resume-import-processor\" }"
        }
      ],
      "description": "TraceQL across ingestion + resume-import. Filter to one via the $pipeline variable. Click any trace to open the waterfall in Tempo."
    },
    {
      "type": "row",
      "title": "Failure Analysis",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "collapsed": false,
      "id": 20
    },
    {
      "type": "timeseries",

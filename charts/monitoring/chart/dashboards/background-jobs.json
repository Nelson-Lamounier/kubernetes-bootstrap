  "title": "Background Jobs — Ingestion + Resume Import",
  "uid": "background-jobs",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "user_id",
        "type": "textbox",
        "label": "User ID",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "trace_id",
        "type": "textbox",
        "label": "Trace ID",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "pipeline",
        "type": "custom",
        "label": "Pipeline",
        "query": "all,ingestion,resume-import",
        "current": {
          "text": "all",
          "value": "all"
        },
        "options": [
          {
            "text": "all",
            "value": "all",
            "selected": true
          },
          {
            "text": "ingestion",
            "value": "ingestion",
            "selected": false
          },
          {
            "text": "resume-import",
            "value": "resume-import",
            "selected": false
          }
        ],
        "description": "Scope panels to one pipeline. \"all\" keeps the cross-pipeline view."
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Health at a Glance — last 24 h",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "id": 1
    },
    {
      "type": "stat",
      "title": "Ingestion jobs — succeeded",
      "id": 2,
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ingestion_runs_total{outcome=\"success\"}[$__range]))",
          "legendFormat": "success"
        }
      ]
    },

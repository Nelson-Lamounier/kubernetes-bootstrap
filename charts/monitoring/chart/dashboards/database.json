    {
      "type": "row",
      "id": 200,
      "title": "PgBouncer connection pool",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      }
    },
    {
      "id": 201,
      "type": "timeseries",
      "title": "Active / waiting clients (per pool)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (database) (pgbouncer_pools_client_active_connections)",
          "legendFormat": "{{database}} active"
        },
        {
          "refId": "B",
          "expr": "sum by (database) (pgbouncer_pools_client_waiting_connections)",
          "legendFormat": "{{database}} waiting"
        }
      ]
    },
    {
      "id": 202,
      "type": "timeseries",
      "title": "Server connections in use",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0

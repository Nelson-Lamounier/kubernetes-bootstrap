  {
   "type": "row",
   "id": 300,
   "title": "App pg activity (from OTel pg instrumentation)",
   "gridPos": {
    "h": 1,
    "w": 24,
    "x": 0,
    "y": 23
   }
  },
  {
   "id": 301,
   "type": "timeseries",
   "title": "DB calls / sec by service",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 24
   },
   "fieldConfig": {
    "defaults": {
     "unit": "ops",
     "min": 0,
     "noValue": "0"
    }
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "right"
    }
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\",db_system=\"postgresql\"}[5m]))",
     "legendFormat": "{{service_name}}"
    }
   ],
   "description": "Client DB spans/sec from OTel tracing. Shows 0 when apps make no DB calls in the window \u2014 that is idle traffic, not a broken panel."
  },
  {
   "id": 302,
   "type": "timeseries",
   "title": "DB call p95 latency by service",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 24
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s",
     "min": 0
    }
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "right"
    }
   },
   "targets": [
    {
     "refId": "A",
     "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_CLIENT\",db_system=\"postgresql\"}[5m])))",
     "legendFormat": "{{service_name}}"
    }
   ],
   "description": "p95 of client DB spans from OTel tracing. Empty when there is no DB traffic in the window (no calls to measure) \u2014 expected when idle."
  },

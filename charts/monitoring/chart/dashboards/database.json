    },
    {
      "type": "row",
      "id": 600,
      "title": "Users & activity (granular — per user / per rank)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 60
      }
    },
    {
      "id": 601,
      "type": "table",
      "title": "Users by plan / role / status",
      "datasource": {
        "type": "postgres",
        "uid": "rds-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 61
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "Scans"
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(plan,'(none)') AS plan, COALESCE(role,'(none)') AS role, COALESCE(subscription_status,'(none)') AS status, COUNT(*) AS users FROM users WHERE deleted_at IS NULL GROUP BY plan, role, subscription_status ORDER BY users DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "description": "Live user composition."
    },
    {
      "id": 602,
      "type": "table",
      "title": "Top users by Bedrock spend (30d)",
      "datasource": {
        "type": "postgres",
        "uid": "rds-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 61
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "Scans"
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT RANK() OVER (ORDER BY SUM(pi.total_cost_cents) DESC) AS rank, u.email, u.plan, COUNT(pi.id) AS calls, ROUND(SUM(pi.total_cost_cents)/100.0,4) AS usd FROM prompt_invocations pi JOIN users u ON u.id=pi.user_id WHERE pi.invoked_at > NOW() - INTERVAL '30 days' GROUP BY u.email, u.plan ORDER BY usd DESC NULLS LAST LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "description": "Ranked spend from prompt_invocations joined to users."
    },
    {
      "id": 603,
      "type": "table",
      "title": "Top users by repos + KB quality",
      "datasource": {
        "type": "postgres",
        "uid": "rds-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 61
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "Scans"
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT RANK() OVER (ORDER BY COUNT(rss.repo_full_name) DESC) AS rank, u.email, u.plan, COUNT(rss.repo_full_name) AS repos, ROUND(AVG(rss.kb_quality_score)::numeric,2) AS avg_kb_quality, ROUND(AVG(rss.retrieval_score)::numeric,2) AS avg_retrieval, MAX(rss.last_synced_at) AS last_synced FROM users u LEFT JOIN repo_sync_state rss ON rss.user_id=u.id WHERE u.deleted_at IS NULL GROUP BY u.email, u.plan ORDER BY repos DESC NULLS LAST LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "description": "Ranked by repos synced; avg KB quality + retrieval from repo_sync_state."
    },
    {
      "id": 604,
      "type": "table",
      "title": "Per-user repos (set $user_email; blank = all)",
      "datasource": {
        "type": "postgres",
        "uid": "rds-postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 69
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "Scans"
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT u.email, rss.repo_full_name, rss.sync_status, COALESCE(rss.last_sync_type,'-') AS sync_type, rss.last_synced_at, rss.file_count, rss.chunk_count, ROUND(rss.kb_quality_score::numeric,2) AS kb_quality, ROUND(rss.retrieval_score::numeric,2) AS retrieval FROM repo_sync_state rss JOIN users u ON u.id=rss.user_id WHERE (${user_email:sqlstring} = '' OR u.email = ${user_email:sqlstring}) ORDER BY rss.last_synced_at DESC NULLS LAST LIMIT 100",

  {
   "id": 404,
   "type": "table",
   "title": "pgvector index health",
   "datasource": {
    "type": "postgres",
    "uid": "rds-postgres"
   },
   "gridPos": {
    "h": 4,
    "w": 12,
    "x": 12,
    "y": 37
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short"
    }
   },
   "options": {
    "sortBy": [
     {
      "desc": true,
      "displayName": "Scans"
     }
    ]
   },
   "targets": [
    {
     "refId": "A",
     "rawSql": "SELECT indexrelname AS \"Index\",\n  pg_size_pretty(pg_relation_size(indexrelid)) AS \"Size\",\n  idx_scan AS \"Scans\",\n  idx_tup_read AS \"Tuples read\",\n  idx_tup_fetch AS \"Tuples fetched\"\nFROM pg_stat_user_indexes\nWHERE relname = 'document_embeddings'\nORDER BY idx_scan DESC",
     "format": "table"
    }
   ]

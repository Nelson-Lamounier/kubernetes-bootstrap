  {
   "type": "row",
   "id": 600,
   "title": "Users & activity (granular \u2014 per user / per rank)",
   "gridPos": {
    "h": 1,
    "w": 24,
    "x": 0,
    "y": 60
   }
  },
  {
   "id": 601,
   "type": "table",
   "title": "Users by plan / role / status",
   "datasource": {
    "type": "postgres",
    "uid": "rds-postgres"
   },
   "gridPos": {
    "h": 8,
    "w": 8,
    "x": 0,
    "y": 61
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short"
    }
   },
   "options": {
    "sortBy": [
     {
      "desc": true,
      "displayName": "Scans"
     }
    ]
   },
   "targets": [
    {
     "rawSql": "SELECT COALESCE(plan,'(none)') AS plan, COALESCE(role,'(none)') AS role, COALESCE(subscription_status,'(none)') AS status, COUNT(*) AS users FROM users WHERE deleted_at IS NULL GROUP BY plan, role, subscription_status ORDER BY users DESC",
     "format": "table",
     "refId": "A"
    }
   ],
   "description": "Live user composition."
  },
  {
   "id": 602,
   "type": "table",
   "title": "Top users by Bedrock spend (30d)",
   "datasource": {
    "type": "postgres",
    "uid": "rds-postgres"
   },
   "gridPos": {
    "h": 8,
    "w": 8,
    "x": 8,
    "y": 61
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short"
    }
   },
   "options": {
    "sortBy": [
     {
      "desc": true,
      "displayName": "Scans"
     }
    ]
   },
   "targets": [
    {
     "rawSql": "SELECT RANK() OVER (ORDER BY SUM(pi.total_cost_cents) DESC) AS rank, u.email, u.plan, COUNT(pi.id) AS calls, ROUND(SUM(pi.total_cost_cents)/100.0,4) AS usd FROM prompt_invocations pi JOIN users u ON u.id=pi.user_id WHERE pi.invoked_at > NOW() - INTERVAL '30 days' GROUP BY u.email, u.plan ORDER BY usd DESC NULLS LAST LIMIT 20",
     "format": "table",
     "refId": "A"
    }
   ],
   "description": "Ranked spend from prompt_invocations joined to users."
  },

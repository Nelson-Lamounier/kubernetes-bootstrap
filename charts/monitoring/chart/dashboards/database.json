      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      }
    },
    {
      "id": 301,
      "type": "timeseries",
      "title": "DB calls / sec by service",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_CLIENT\",db_system=\"postgresql\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 302,
      "type": "timeseries",
      "title": "DB call p95 latency by service",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_CLIENT\",db_system=\"postgresql\"}[5m])))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "type": "row",
      "id": 400,
      "title": "pgvector — embeddings tables",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      }
    },
    {
      "id": 401,
      "type": "table",
      "title": "Vectors by repo (document_embeddings)",
      "datasource": {
        "type": "postgres",
        "uid": "rds-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "displayName": "embeddings / interval"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "rawSql": "SELECT repo_full_name, COUNT(*) AS vectors FROM document_embeddings GROUP BY repo_full_name ORDER BY vectors DESC LIMIT 25",
          "format": "table",
          "refId": "A"
        }
      ],
      "description": "Vector rows per repo in document_embeddings (the RAG store)."
    },
    {
      "id": 402,
      "type": "stat",
      "title": "Total vectors",
      "datasource": {
        "type": "postgres",
        "uid": "rds-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT count(*) AS \"Total vectors\" FROM document_embeddings",
          "format": "table"
        }
      ]
    },
    {
      "id": 403,
      "type": "stat",
      "title": "Table size",
      "datasource": {
        "type": "postgres",
        "uid": "rds-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT pg_relation_size('document_embeddings') AS \"bytes\"",
          "format": "table"
        }
      ]
    },
    {
      "id": 404,
      "type": "table",
      "title": "pgvector index health",
      "datasource": {
        "type": "postgres",
        "uid": "rds-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 37
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "Scans"
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT indexrelname AS \"Index\",\n  pg_size_pretty(pg_relation_size(indexrelid)) AS \"Size\",\n  idx_scan AS \"Scans\",\n  idx_tup_read AS \"Tuples read\",\n  idx_tup_fetch AS \"Tuples fetched\"\nFROM pg_stat_user_indexes\nWHERE relname = 'document_embeddings'\nORDER BY idx_scan DESC",
          "format": "table"
        }
      ]
    },
    {
      "type": "row",
      "id": 500,
      "title": "RDS PostgreSQL logs",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 41
      }
    },
    {
      "id": 501,
      "type": "logs",
      "title": "Recent errors / warnings",
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 42
      },
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Logs",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:771826808455:log-group:/aws/rds/instance/${db_identifier}/postgresql:*",
              "name": "/aws/rds/instance/${db_identifier}/postgresql"
            }
          ],
          "expression": "fields @timestamp, @message | filter @message like /ERROR|FATAL|PANIC|WARNING/ | sort @timestamp desc | limit 200",
          "region": "eu-west-1"
        }
      ]
    },
    {
      "id": 502,
      "type": "timeseries",
      "title": "Error / warning rate",
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 52
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Logs",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:771826808455:log-group:/aws/rds/instance/${db_identifier}/postgresql:*",
              "name": "/aws/rds/instance/${db_identifier}/postgresql"
            }
          ],
          "expression": "filter @message like /ERROR|FATAL|WARNING/ | stats count() as log_count by bin(1m)",
          "region": "eu-west-1"
        }
      ]
    },
    {
      "id": 503,
      "type": "timeseries",
      "title": "Connection events / min",
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 52
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Logs",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:771826808455:log-group:/aws/rds/instance/${db_identifier}/postgresql:*",
              "name": "/aws/rds/instance/${db_identifier}/postgresql"
            }
          ],
          "expression": "filter @message like /connection received|connection authorized|disconnection/ | stats count() as connections by bin(1m)",
          "region": "eu-west-1"
        }

   "targets": [
    {
     "rawSql": "SELECT RANK() OVER (ORDER BY COUNT(rss.repo_full_name) DESC) AS rank, u.email, u.plan, COUNT(rss.repo_full_name) AS repos, ROUND(AVG(rss.kb_quality_score)::numeric,2) AS avg_kb_quality, ROUND(AVG(rss.retrieval_score)::numeric,2) AS avg_retrieval, MAX(rss.last_synced_at) AS last_synced FROM users u LEFT JOIN repo_sync_state rss ON rss.user_id=u.id WHERE u.deleted_at IS NULL GROUP BY u.email, u.plan ORDER BY repos DESC NULLS LAST LIMIT 20",
     "format": "table",
     "refId": "A"
    }
   ],
   "description": "Ranked by repos synced; avg KB quality + retrieval from repo_sync_state."
  },

    {
      "id": 101,
      "type": "stat",
      "title": "CPU",
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/RDS",
          "metricName": "CPUUtilization",
          "statistic": "Average",
          "dimensionFilters": {
            "DBInstanceIdentifier": "${db_identifier}"
          }
        }
      ]

{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "tags": ["tempo", "service-graph", "tracing"],
  "title": "Service Graph — auto-derived from spans",
  "uid": "service-graph",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "links": [
    { "title": "Open Tempo Service Graph view", "type": "link", "url": "/explore?left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22queryType%22:%22serviceMap%22%7D%5D%7D", "icon": "external link", "targetBlank": true }
  ],
  "panels": [
    {
      "id": 1,
      "type": "nodeGraph",
      "title": "Service map (browser → SSR → admin-api → pg)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "queryType": "serviceMap" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Edge request rate (Tempo span_metrics)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "sum by (client, server) (rate(traces_service_graph_request_total[5m]))", "legendFormat": "{{client}} → {{server}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Edge p95 server latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, client, server) (rate(traces_service_graph_request_server_seconds_bucket[5m])))", "legendFormat": "{{client}} → {{server}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Edge failure ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "sum by (client, server) (rate(traces_service_graph_request_failed_total[5m])) / clamp_min(sum by (client, server) (rate(traces_service_graph_request_total[5m])), 1)", "legendFormat": "{{client}} → {{server}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Span calls per service / span_name (Tempo span_metrics)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (service_name, span_name) (rate(traces_spanmetrics_calls_total[5m])))", "legendFormat": "{{service_name}} {{span_name}}" }
      ]
    }
  ]
}

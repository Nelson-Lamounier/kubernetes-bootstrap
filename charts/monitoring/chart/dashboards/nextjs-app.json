{
  "uid": "nextjs-app",
  "title": "Next.js App \u2014 Portfolio Application Metrics",
  "tags": [
    "nextjs",
    "portfolio",
    "frontend",
    "application",
    "red"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "timezone": "",
  "style": "dark",
  "links": [
    {
      "title": "Frontend & RUM",
      "type": "link",
      "icon": "external link",
      "url": "/d/frontend-rum",
      "targetBlank": false
    },
    {
      "title": "Networking",
      "type": "link",
      "icon": "external link",
      "url": "/d/networking",
      "targetBlank": false
    },
    {
      "title": "Edge & CDN",
      "type": "link",
      "icon": "external link",
      "url": "/d/edge-cdn",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "custom",
        "label": "Scrape job",
        "query": "nextjs-app,nextjs-app-preview",
        "current": {
          "text": "nextjs-app",
          "value": "nextjs-app"
        },
        "options": [
          {
            "text": "nextjs-app",
            "value": "nextjs-app",
            "selected": true
          },
          {
            "text": "nextjs-app-preview",
            "value": "nextjs-app-preview",
            "selected": false
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Up",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "nextjs_up{job=\"$job\"}",
          "refId": "A",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Requests/s",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 4,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(nextjs_http_request_duration_seconds_count{job=\"$job\"}[$__rate_interval]))",
          "refId": "B",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error % (5xx)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 9,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100*sum(rate(nextjs_http_request_duration_seconds_count{job=\"$job\",status=~\"5..\"}[$__rate_interval]))/clamp_min(sum(rate(nextjs_http_request_duration_seconds_count{job=\"$job\"}[$__rate_interval])),1)",
          "refId": "C",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p95 latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "decimals": 3
        },
        "overrides": []

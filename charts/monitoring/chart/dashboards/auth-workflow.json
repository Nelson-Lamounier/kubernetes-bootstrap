{
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "expr": "{job=\"github-actions\", event=~\"deploy_succeeded|deploy_failed\", service=~\"admin-api|tucaken-app\"} | json",
        "iconColor": "blue",
        "titleFormat": "{{event}} {{service}} {{git_sha}}",
        "textFormat": "{{run_url}}"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "BFF RED",
      "url": "/d/bff-red",
      "type": "link",
      "targetBlank": false,
      "icon": "external link"
    }
  ],
  "tags": ["auth", "sign-in", "sign-up", "tucaken", "admin-api"],
  "title": "Auth — Sign-In / Sign-Up Workflow",
  "uid": "auth-workflow",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "label": "Environment",
        "query": "development,production",
        "current": { "text": "development", "value": "development" },
        "options": [
          { "text": "development", "value": "development", "selected": true },
          { "text": "production",  "value": "production",  "selected": false }
        ]
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Auth Funnel — totals (time window)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 101,
      "type": "stat",
      "title": "New users provisioned",
      "description": "First-ever sign-ins that created a new users row in RDS. Counter incremented by userProvisionMiddleware when isNew=true.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "increase(auth_provision_total{service=\"admin-api\",outcome=\"new_user\"}[24h])" }
      ]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Returning sign-ins",
      "description": "Successful /api/admin/me calls where the sub was already provisioned (pod-cache hit or returning user upsert). Includes both password and OAuth flows.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "increase(auth_provision_total{service=\"admin-api\",outcome=\"returning\"}[24h])" }
      ]
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Provision errors",
      "description": "upsertUser() threw — user was not provisioned, /me returned 503. Indicates DB connectivity or migration issues.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "targets": [
        { "refId": "A", "expr": "increase(auth_provision_total{service=\"admin-api\",outcome=\"error\"}[24h])" }
      ]
    },
    {
      "id": 104,
      "type": "stat",
      "title": "/me 401s (bad / expired token)",
      "description": "Requests to /api/admin/me that failed JWT verification. A spike here means clients are sending expired or invalid session cookies.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "targets": [
        { "refId": "A", "expr": "increase(http_requests_total{service=\"admin-api\",route=\"/api/admin/me\",status_code=\"401\"}[24h])" }
      ]
    },

    {
      "type": "row",
      "id": 200,
      "title": "Step-by-Step — request rates through the auth flow",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 201,
      "type": "timeseries",
      "title": "email-exists pre-check rate (sign-up guard)",
      "description": "Rate of GET /api/public/email-exists calls from tucaken-app before Cognito SignUpCommand. A 200+exists=true means a duplicate account was blocked before Cognito saw the request.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_code) (rate(http_requests_total{service=\"admin-api\",route=\"/api/public/email-exists\"}[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 202,
      "type": "timeseries",
      "title": "/api/admin/me — provisioning outcomes / sec",
      "description": "Rate of user provision outcomes. new_user = first INSERT; returning = known sub; error = upsert threw. Spikes in 'error' indicate DB issues blocking new sign-ins.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(auth_provision_total{service=\"admin-api\"}[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },

    {
      "type": "row",
      "id": 300,
      "title": "Latency — auth endpoint response times",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 301,
      "type": "timeseries",
      "title": "/api/admin/me latency (p50 / p95 / p99)",
      "description": "Server-side latency for the /me endpoint. Includes JWT verification, pod-cache lookup, DB upsert (slow path), and plan query. p95 > 500ms may indicate pgbouncer contention.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"admin-api\",route=\"/api/admin/me\"}[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"admin-api\",route=\"/api/admin/me\"}[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"admin-api\",route=\"/api/admin/me\"}[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 302,
      "type": "timeseries",
      "title": "detectNewUser round-trip (tucaken-app → admin-api)",
      "description": "End-to-end latency of the outbound call from tucaken-app to /api/admin/me after Cognito token exchange. Includes network hop + /me server time. Measured at the tucaken-app client.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(admin_api_client_request_duration_seconds_bucket{service=\"tucaken-app\",path=\"/api/admin/me\"}[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(admin_api_client_request_duration_seconds_bucket{service=\"tucaken-app\",path=\"/api/admin/me\"}[5m])))", "legendFormat": "p95" }
      ]
    },

    {
      "type": "row",
      "id": 400,
      "title": "Errors — auth failure breakdown",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 401,
      "type": "timeseries",
      "title": "/api/admin/me — responses by status code",
      "description": "401 = JWT invalid/expired. 503 = userProvisionMiddleware failed (DB down). 200 = success. Any 503 during an auth flow = user cannot complete sign-in/sign-up.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_code) (rate(http_requests_total{service=\"admin-api\",route=\"/api/admin/me\"}[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 402,
      "type": "timeseries",
      "title": "/api/public/email-exists — 4xx rate (bad input)",
      "description": "400s on the email-exists endpoint indicate malformed email inputs reaching the server — client-side Zod validation should prevent this. Worth monitoring after auth form changes.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_code) (rate(http_requests_total{service=\"admin-api\",route=\"/api/public/email-exists\",status_code=~\"4..\"}[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },

    {
      "type": "row",
      "id": 500,
      "title": "Logs — auth event stream",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "id": 501,
      "type": "logs",
      "title": "User provisioning events (admin-api)",
      "description": "Structured pino logs emitted by userProvisionMiddleware: new_user on first INSERT, error on upsert failure. Each line carries trace_id for Tempo pivot.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 33 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "exact", "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=\"admin-api\"} | json | event=~\"user_provisioned|user_provision_failed|user_provision_missing\""
        }
      ]
    },
    {
      "id": 502,
      "type": "logs",
      "title": "Auth errors — admin-api (JWT + provisioning)",
      "description": "All error-level log lines from admin-api scoped to auth paths. Includes JWT verification failures (logged by observability middleware at warn/error) and provision errors.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 33 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "exact", "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=\"admin-api\"} | json | level=~\"warn|error\" | route=~\"/api/admin/me|/api/public/email-exists\""
        }
      ]
    },

    {
      "type": "row",
      "id": 600,
      "title": "Logs — tucaken-app auth server functions",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "collapsed": false
    },
    {
      "id": 601,
      "type": "logs",
      "title": "Auth server fn events (tucaken-app)",
      "description": "Structured JSON logs from auth.ts server functions: signin_success, signin_failed, signup_initiated, signup_confirmed, signup_blocked. Emitted to stdout and scraped by Alloy.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 44 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "exact", "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=\"tucaken-app\"} | json | event=~\"auth_signin.*|auth_signup.*|auth_detect_new_user.*\""
        }
      ]
    },

    {
      "type": "row",
      "id": 700,
      "title": "Traces — Tempo pivot",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 56 },
      "collapsed": false
    },
    {
      "id": 701,
      "type": "traces",
      "title": "Recent /api/admin/me traces",
      "description": "Distributed traces for the /api/admin/me endpoint via Tempo. Drill into any span to see JWT verification + DB upsert timing. Use trace_id from the log panels above to navigate directly.",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 57 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{resource.service.name=\"admin-api\" && span.http.route=\"/api/admin/me\"}"
        }
      ]
    }
  ]
}

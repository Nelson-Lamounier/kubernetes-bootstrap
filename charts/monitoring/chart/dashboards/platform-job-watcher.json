{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["platform-job-watcher", "k8s-jobs", "observability"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "Platform Job Watcher",
  "uid": "platform-job-watcher",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Watched Namespace",
        "type": "custom",
        "query": "resume-import,platform",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all" },
          { "text": "resume-import", "value": "resume-import" },
          { "text": "platform", "value": "platform" }
        ],
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "👁️ Watch Stream Health",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Total watch stream reconnect events in the selected time range — high counts indicate network instability",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background_gradient",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"reconnecting\" [$__range]))",
          "legendFormat": "Reconnects",
          "refId": "A"
        }
      ],
      "title": "Stream Reconnects",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Total JOB_FAILED marks written to the database across all watched namespaces",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background_gradient",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"JOB_FAILED\" [$__range]))",
          "legendFormat": "JOB_FAILED marks",
          "refId": "A"
        }
      ],
      "title": "JOB_FAILED Marks Written",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Total WATCHER_TIMEOUT marks written by the reconciler sweep (imports stuck >15m)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background_gradient",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"WATCHER_TIMEOUT\" [$__range]))",
          "legendFormat": "WATCHER_TIMEOUT marks",
          "refId": "A"
        }
      ],
      "title": "WATCHER_TIMEOUT Marks (Reconciler)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Memory working set of the watcher pod — should be flat; growth indicates a leak",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(container_memory_working_set_bytes{namespace=\"platform\", pod=~\"platform-job-watcher.*\", container!=\"\"})",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ],
      "title": "Watcher Pod Memory",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Rate of watch stream reconnect events per namespace over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (namespace_watched) (rate({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"reconnecting\" | json | line_format \"{{.namespace}}\" [$__interval]))",
          "legendFormat": "{{namespace_watched}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"reconnecting\" [$__interval]))",
          "legendFormat": "total",
          "refId": "B"
        }
      ],
      "title": "Stream Reconnects Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Rate of failed watch stream open attempts (before reconnect)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"failed to open watch stream\" [$__interval]))",
          "legendFormat": "Stream open errors",
          "refId": "A"
        }
      ],
      "title": "Watch Stream Open Errors",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 200,
      "title": "💀 JOB_FAILED Marks per Namespace",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Rate of JOB_FAILED marks written per watched namespace over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (table) (rate({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"marked import as JOB_FAILED\" | json | table != \"\" [5m]))",
          "legendFormat": "{{table}}",
          "refId": "A"
        }
      ],
      "title": "JOB_FAILED Rate by DB Table",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Watcher log lines where markJobFailed found no rows to update — import was already in a terminal state",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"no rows updated\" [5m]))",
          "legendFormat": "Already terminal",
          "refId": "A"
        }
      ],
      "title": "Late Marks (Already Terminal)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 300,
      "title": "⏱️ Reconciler Sweep Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Rate of reconciler sweeps completing (runs every 5 minutes per configured watcher entry)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"[reconciler]\" [5m]))",
          "legendFormat": "Reconciler activity",
          "refId": "A"
        }
      ],
      "title": "Reconciler Sweep Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Rate of WATCHER_TIMEOUT marks written by the reconciler — these are stale imports that the watch stream missed",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({namespace=\"platform\", app=\"platform-job-watcher\"} |= \"WATCHER_TIMEOUT\" [5m]))",
          "legendFormat": "Timeout marks/s",
          "refId": "A"
        }
      ],
      "title": "WATCHER_TIMEOUT Rate (Reconciler Catch)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 400,
      "title": "⚙️ Watcher Resource Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "CPU cores consumed by the watcher pod over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" },
          "unit": "cores"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 32 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"platform\", pod=~\"platform-job-watcher.*\", container!=\"\"}[5m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Memory working set of the watcher pod over time — should be flat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 32 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"platform\", pod=~\"platform-job-watcher.*\", container!=\"\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Memory Working Set",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 500,
      "title": "📋 Live Watcher Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Live structured logs from the platform-job-watcher pod",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 40 },
      "id": 13,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{namespace=\"platform\", app=\"platform-job-watcher\"}",
          "refId": "A"
        }
      ],
      "title": "Watcher — Live Logs",
      "type": "logs"
    }
  ]
}

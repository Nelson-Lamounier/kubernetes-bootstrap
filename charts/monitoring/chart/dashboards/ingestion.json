      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_profile_embed_duration_seconds_sum{instance=\"$repoInstance\"}) / clamp_min(sum(ingestion_profile_embed_duration_seconds_count{instance=\"$repoInstance\"}), 1)"
        }
      ]
    },
    {
      "id": 205,
      "type": "stat",
      "title": "Chunk-ingest sec (avg)",
      "description": "orchestrator.ingestRepo wall-clock — chunk + enrich + embed + persist.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_chunk_ingest_duration_seconds_sum{instance=\"$repoInstance\"}) / clamp_min(sum(ingestion_chunk_ingest_duration_seconds_count{instance=\"$repoInstance\"}), 1)"
        }
      ]
    },
    {
      "id": 206,
      "type": "stat",
      "title": "KB quality score",
      "description": "scoreProfile() output (0..1). Low score = sparse evidence in the repo.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]

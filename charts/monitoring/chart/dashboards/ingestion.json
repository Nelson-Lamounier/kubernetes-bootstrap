        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_kb_quality_score_sum{instance=\"$repoInstance\"}) / clamp_min(sum(ingestion_kb_quality_score_count{instance=\"$repoInstance\"}), 1)"
        }
      ]
    },
    {
      "id": 210,
      "type": "logs",
      "title": "$repoFullName — full pipeline timeline (Loki)",
      "description": "All log lines from the ingestion-worker pod for this repo, ordered ascending — reads top → bottom as a waterfall.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "options": {
        "dedupStrategy": "none",
        "showTime": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true,
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=\"ingestion\", service_name=\"ingestion-worker\"} | json | __error__=\"\" | repo_full_name=\"$repoFullName\" | line_format \"{{.time}} [{{.level}}] event={{.event}} {{.msg}} embedded={{.embedded}} pruned={{.pruned}} dur_ms={{.duration_ms}} err={{.err}}\""
        }
      ]
    },
    {
      "id": 211,
      "type": "traces",
      "title": "$repoFullName — Tempo span waterfall",
      "description": "Tempo trace for resource.service.name=ingestion with the chosen repo.full_name. Click into spans for ingestion.chunk / ingestion.enrich / ingestion.embed_upsert / ingestion.prune timings.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ resource.service.name=\"ingestion\" && span.repo.full_name=\"$repoFullName\" && span.user.id=\"$userId\" }"
        }
      ]
    },
    {
      "id": 300,
      "type": "row",
      "title": "Sub-stage latencies (fleet, cumulative)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      }
    },
    {
      "id": 301,
      "type": "timeseries",
      "title": "Profile-extraction p50/p95",
      "description": "Bedrock InvokeModel duration for repository profile extraction across the fleet.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (ingestion_profile_extract_duration_seconds_bucket))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (ingestion_profile_extract_duration_seconds_bucket))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 302,

{
  "title": "Ingestion — Repo Profiles + Chunk Embedding",
  "uid": "ingestion",
  "tags": [
    "ingestion",
    "repo-sync",
    "profile-extraction",
    "background-jobs",
    "tucaken"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "links": [
    {
      "title": "Background Jobs (overview)",
      "type": "link",
      "url": "/d/background-jobs",
      "icon": "external link",
      "targetBlank": false,
      "tags": []
    },
    {
      "title": "Resume Import (sibling pipeline)",
      "type": "link",
      "url": "/d/resume-import",
      "icon": "external link",
      "targetBlank": false,
      "tags": []
    }
  ],
  "templating": {
    "list": [
      {
        "name": "userId",
        "type": "textbox",
        "label": "User ID",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "description": "UUID of the GitHub user whose ingestion you want to drill into. Used in Tempo waterfall filter."
      },
      {
        "name": "repoFullName",
        "type": "textbox",
        "label": "Repo (owner/name)",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "description": "GitHub repo full name with slashes (e.g. Nelson-Lamounier/ai-applications). Used in Tempo waterfall + Loki timeline filters."
      },
      {
        "name": "repoInstance",
        "type": "query",
        "label": "Pushgateway instance",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(ingestion_runs_total, instance)",
        "query": {
          "qryType": 1,
          "query": "label_values(ingestion_runs_total, instance)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {},
        "options": [],
        "description": "Pushgateway grouping label <userId>_<owner>_<repo> for a single ingestion run. Populated from ingestion_runs_total instance labels — pick from the dropdown. Used by the per-repo drill-down panels."
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Health at a glance — cumulative (Pushgateway)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Runs succeeded",
      "description": "ingestion_runs_total{outcome=success} increase over 24h.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_runs_total{outcome=\"success\"})"
        }
      ]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Runs failed",
      "description": "ingestion_runs_total{outcome=failed}.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_runs_total{outcome=\"failed\"})"
        }
      ]
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Active K8s jobs now",
      "description": "Live count of running ingestion Jobs in the ingestion ns.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_job_status_active{namespace=\"ingestion\"}) or vector(0)"
        }
      ]
    },
    {
      "id": 104,
      "type": "stat",
      "title": "Chunks embedded (total)",
      "description": "ingestion_chunks_total{phase=embedded} — newly-written vector rows.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_chunks_total{phase=\"embedded\"})"
        }
      ]
    },
    {
      "id": 105,
      "type": "stat",
      "title": "Chunks skipped (total)",
      "description": "Files already up-to-date (content hash unchanged).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_chunks_total{phase=\"skipped\"})"
        }
      ]
    },
    {
      "id": 106,
      "type": "stat",
      "title": "Chunks pruned (total)",
      "description": "Files removed from vector store because they no longer exist in the repo.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_chunks_total{phase=\"pruned\"})"
        }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "Per-repo drill-down — pick $repoInstance for metrics; $repoFullName + $userId drive the Loki/Tempo panels",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "id": 201,
      "type": "stat",
      "title": "Avg run duration",
      "description": "ingestion_duration_seconds_sum / _count for this instance — average wall-clock per run. Uses _sum/_count because metrics are pushAdd'd to Pushgateway (re-runs of the same userId+repo accumulate), so bare _sum would be the total across all runs, not one run's time.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_duration_seconds_sum{instance=\"$repoInstance\"}) / clamp_min(sum(ingestion_duration_seconds_count{instance=\"$repoInstance\"}), 1)"
        }
      ]
    },
    {
      "id": 202,
      "type": "stat",
      "title": "Profile collect sec (avg)",
      "description": "GitHub fetch time for profile-input files (README, package.json, etc.).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_profile_collect_duration_seconds_sum{instance=\"$repoInstance\"}) / clamp_min(sum(ingestion_profile_collect_duration_seconds_count{instance=\"$repoInstance\"}), 1)"
        }
      ]
    },
    {
      "id": 203,
      "type": "stat",
      "title": "Profile extract sec (avg)",
      "description": "Bedrock InvokeModel time for repository profile extraction.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ingestion_profile_extract_duration_seconds_sum{instance=\"$repoInstance\"}) / clamp_min(sum(ingestion_profile_extract_duration_seconds_count{instance=\"$repoInstance\"}), 1)"
        }
      ]
    },
    {
      "id": 204,
      "type": "stat",
      "title": "Profile embed sec (avg)",
      "description": "Titan embedding time for profile (one_liner + description + highlights).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
